{
	"name": "cz101-presets-library",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "bun run build:wasm && bun run build:web && bun run build:plugin",
		"build:web": "tsc && vite build",
		"build:wasm": "wasm-pack build src-tauri/cz-synth --target no-modules --out-dir ../../public/cz-synth-wasm --features wasm",
		"build:tauri": "tauri build --config src-tauri/tauri-app/tauri.conf.json",
		"build:plugin": "bash scripts/build-plugin.sh --release",
		"build:plugin:debug": "bash scripts/build-plugin.sh debug",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "tauri dev --config src-tauri/tauri-app/tauri.conf.json",
		"tauri:build": "tauri build --config src-tauri/tauri-app/tauri.conf.json",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"test": "vitest --project unit",
		"test:unit": "vitest --project unit",
		"test:browser": "vitest --project browser",
		"test:all": "vitest",
		"test:component": "vitest --project unit --run src/features/ src/components/",
		"test:component:watch": "vitest --project unit src/features/ src/components/",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage --project unit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"plugin:install": "bash scripts/install-plugin.sh",
		"plugin:build-install": "bun run build && bun run plugin:install",
		"plugin:build-install:debug": "bun run build:wasm && bun run build:web && bun run build:plugin:debug && bun run plugin:install"
	},
	"dependencies": {
		"@infinite-table/infinite-react": "^6.2.12",
		"@neondatabase/neon-js": "^0.2.0-beta.1",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/intent": "^0.0.29",
		"@tanstack/react-query": "^5.96.2",
		"@tanstack/react-router": "^1.168.10",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.23",
		"@tanstack/router-core": "^1.168.9",
		"@tauri-apps/api": "~2.5.0",
		"@tauri-apps/plugin-dialog": "~2.2.0",
		"@tauri-apps/plugin-fs": "~2.3.0",
		"@tauri-apps/plugin-shell": "~2.2.0",
		"@types/pg": "^8.20.0",
		"drizzle-orm": "^0.45.2",
		"natsort": "^2.0.3",
		"pg": "^8.20.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-icons": "^5.6.0",
		"react-virtualized-auto-sizer": "^1.0.26",
		"react-window": "^1.8.11",
		"react-window-infinite-loader": "^1.0.10",
		"uuid": "^11.1.0",
		"webmidi": "^3.1.16"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.17",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/browser": "^4.1.2",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/ui": "^4.1.2",
		"autoprefixer": "^10.4.27",
		"daisyui": "^5.5.19",
		"dotenv": "^17.4.0",
		"drizzle-kit": "^0.31.10",
		"fake-indexeddb": "^6.2.5",
		"happy-dom": "^20.8.9",
		"playwright": "^1.59.1",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^6.4.2",
		"vitest": "^4.1.2",
		"vitest-axe": "^0.1.0",
		"vitest-browser-react": "^2.2.0"
	}
}
