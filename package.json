{
	"name": "cz101-presets-library",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun --filter @cz101/cz-explorer dev",
		"build": "bun run build:web && bun run build:plugin && bun run build:standalone",
		"build:engine": "bun --filter @cz101/cosmo-synth-engine build:wasm",
		"build:web": "bun --filter @cz101/cosmo-synth-engine build:wasm && bun --filter @cz101/cz-explorer build",
		"build:plugin": "bun --filter @cz101/cosmo-pd101 bundle:release",
		"build:standalone": "bun --filter @cz101/cz-explorer-desktop build",
		"test": "bun --filter @cz101/cz-explorer test:all && cargo test --workspace",
		"lint": "bun --filter @cz101/cz-explorer lint && cargo fmt --all --check && cargo clippy --workspace --all-targets",
		"clean": "find . -type d \\( -name dist -o -name target \\) -not -path '*/node_modules/*' -not -path '*/.git/*' -exec rm -rf {} +",
		"ci": "bun run lint && bun run build && bun run test"
	}
}
