{
	"name": "cosmo-presets-library",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"packages/*",
		"packages/*/webview"
	],
	"scripts": {
		"postinstall": "bun run scripts/install-wasm-pack.mjs",
		"dev": "bun --filter @cosmo/cz-explorer dev",
		"build": "bun run build:web && bun run build:standalone",
		"build:engine": "bun --filter @cosmo/cosmo-synth-engine build:wasm",
		"build:web": "bun --filter @cosmo/cosmo-synth-engine build:wasm && bun --filter @cosmo/cz-explorer build",
		"build:plugin": "bun --filter @cosmo/cosmo-pd101-plugin build",
		"plugin:install": "bun --filter @cosmo/cosmo-pd101-plugin plugin:install",
		"build:standalone": "bun --filter @cosmo/cz-explorer-desktop build",
		"package:plugin:installer": "bun run scripts/package-plugin-installers.mjs",
		"package:plugin:installer:macos": "bun run scripts/package-plugin-installers.mjs --platform macos",
		"package:plugin:installer:windows": "bun run scripts/package-plugin-installers.mjs --platform windows",
		"package:plugin:installer:linux": "bun run scripts/package-plugin-installers.mjs --platform linux",
		"test": "bun --filter '*' test && cargo test --workspace",
		"lint": "bunx biome check . && bun run scripts/cargo-fmt-workspace.mjs --check && cargo clippy --workspace --all-targets",
		"lint:fix:biome": "bunx biome check --write .",
		"lint:fix:cargo": "bun run scripts/cargo-fmt-workspace.mjs",
		"lint:fix": "bun run lint:fix:biome && bun run lint:fix:cargo",
		"clean": "rimraf --glob packages/*/dist packages/**/lib-dist packages/*/target src-tauri/target",
		"ci": "bun run lint && bun run build && bun run test"
	},
	"dependencies": {
		"tailwindcss": "^4.2.4"
	},
	"devDependencies": {
		"cross-env": "^10.1.0",
		"rimraf": "^6.1.3"
	}
}
