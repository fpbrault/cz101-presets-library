{
	"name": "@cosmo/cz-explorer",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"gen:bindings": "SPECTA_TS_EXPORT_PATH=./src/lib/synth/bindings/synth.ts cargo run --features specta-bindings --bin export-specta-bindings --manifest-path ../cosmo-synth-engine/Cargo.toml",
		"preview": "vite preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"test": "vitest --project unit",
		"test:unit": "vitest --project unit",
		"test:browser": "vitest --project browser",
		"test:all": "vitest",
		"test:component": "vitest --project unit --run src/features/ src/components/",
		"test:component:watch": "vitest --project unit src/features/ src/components/",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage --project unit",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"@infinite-table/infinite-react": "^6.2.12",
		"@neondatabase/neon-js": "^0.2.0-beta.1",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/intent": "^0.0.29",
		"@tanstack/react-query": "^5.99.0",
		"@tanstack/react-router": "^1.168.22",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.23",
		"@tanstack/router-core": "^1.168.15",
		"@tauri-apps/api": "~2.5.0",
		"@tauri-apps/plugin-dialog": "~2.2.2",
		"@tauri-apps/plugin-fs": "~2.3.0",
		"@tauri-apps/plugin-shell": "~2.2.2",
		"@types/pg": "^8.20.0",
		"drizzle-orm": "^0.45.2",
		"i18next": "^26.0.6",
		"natsort": "^2.0.3",
		"pg": "^8.20.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^17.0.4",
		"react-icons": "^5.6.0",
		"react-virtualized-auto-sizer": "^1.0.26",
		"react-window": "^1.8.11",
		"react-window-infinite-loader": "^1.0.10",
		"uuid": "^11.1.0",
		"webmidi": "^3.1.16"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.17",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/ui": "^4.1.4",
		"autoprefixer": "^10.5.0",
		"daisyui": "^5.5.19",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"fake-indexeddb": "^6.2.5",
		"happy-dom": "^20.9.0",
		"playwright": "^1.59.1",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^6.4.2",
		"vitest": "^4.1.4",
		"vitest-axe": "^0.1.0",
		"vitest-browser-react": "^2.2.0"
	}
