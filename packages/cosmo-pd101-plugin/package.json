{
	"name": "@cosmo/cosmo-pd101-plugin",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"build": "bun run ../../scripts/build-plugin.mjs --release --auv2 --vst3 --clap",
		"plugin:install": "bash ../../scripts/install-plugin.sh",
		"build:web": "bun --filter @cosmo/cosmo-pd101-plugin-webview build",
		"dev": "cd webview && bun run dev:test",
		"test:unit": "cd webview && bun run test:unit",
		"test:unit:watch": "cd webview && bun run test:unit:watch",
		"test:browser": "cd webview && bun run test:browser",
		"test:all": "cd webview && bun run test:all",
		"test:e2e": "cd webview && bun run test:e2e",
		"test:e2e:ui": "cd webview && bun run test:e2e:ui",
		"test:e2e:debug": "cd webview && bun run test:e2e:debug",
		"package:installer": "bun run package:installer:macos && bun run package:installer:windows && bun run package:installer:linux",
		"package:installer:macos": "bun run ../../scripts/package-plugin-installers.mjs --platform macos",
		"package:installer:windows": "bun run ../../scripts/package-plugin-installers.mjs --platform windows",
		"package:installer:linux": "bun run ../../scripts/package-plugin-installers.mjs --platform linux"
	}
}
