{
	"name": "@cosmo/cosmo-pd101-webview",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"scripts": {
		"dev": "bunx --bun vite",
		"dev:test": "VITE_TEST_HARNESS=1 VITE_DEBUG_PANEL=1 bunx --bun vite",
		"build": "bunx --bun vite build",
		"build:lib": "bunx tsdown src/index.ts --format esm --dts --out-dir lib-dist --clean --no-bundle",
		"build:lib:watch": "bunx tsdown src/index.ts --format esm --dts --out-dir lib-dist --clean --no-bundle --watch",
		"gen:bindings": "SPECTA_TS_EXPORT_PATH=./src/lib/synth/bindings/synth.ts cargo run --features specta-bindings --bin export-specta-bindings --manifest-path ../cosmo-synth-engine/Cargo.toml",
		"test:unit": "bunx vitest --project unit --run",
		"test:unit:watch": "bunx vitest --project unit",
		"test:browser": "bunx vitest --project browser --run",
		"test:all": "bunx vitest --run",
		"test:e2e": "bunx playwright test",
		"test:e2e:ui": "bunx playwright test --ui",
		"test:e2e:debug": "PWDEBUG=1 bunx playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.4",
		"@vitest/ui": "4.1.5",
		"daisyui": "^5.5.19",
		"happy-dom": "^20.9.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwindcss": "^4.2.2",
		"tsdown": "latest",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.4",
		"@testing-library/react": "^16.3.2"
	},
	"peerDependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"dependencies": {
		"i18next": "^26.0.6",
		"motion": "^12.38.0",
		"react-i18next": "^17.0.4",
		"zustand": "^5.0.12"
	}
}
