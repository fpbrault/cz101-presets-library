{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@/lib/*": ["../../../packages/cz-explorer/src/lib/*"],
			"@/*": ["./src/*"]
		},
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmit": true
	},
	"include": [
		"src",
		"../../../packages/cz-explorer/src/lib",
		"../../../packages/cz-explorer/src/vite-env.d.ts"
	]
}
