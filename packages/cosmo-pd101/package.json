{
	"name": "@cosmo/cosmo-pd101",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./webview/dist/index.d.mts",
			"import": "./webview/dist/index.mjs"
		}
	},
	"main": "./webview/dist/index.mjs",
	"types": "./webview/dist/index.d.mts",
	"scripts": {
		"build:lib": "bun --cwd webview run build:lib",
		"bundle:debug": "cargo run --target-dir packages/xtask/target -p xtask -- bundle cosmo-pd101 --vst3 --auv2",
		"bundle:release": "cargo run --target-dir packages/xtask/target -p xtask -- bundle cosmo-pd101 --vst3 --auv2 --release",
		"bundle:release:universal": "ARCH=universal bash ../../scripts/build-plugin.sh --release",
		"bundle:debug:all": "BUILD_AUV3=1 bash ../../scripts/build-plugin.sh debug",
		"bundle:release:all": "BUILD_AUV3=1 bash ../../scripts/build-plugin.sh --release",
		"plugin:install": "bash ../../scripts/install-plugin.sh",
		"install:debug": "PROFILE=debug bash ../../scripts/install-plugin.sh",
		"install:all": "INSTALL_AUV3=1 REMOVE_INSTALLED_AUV3=0 bash ../../scripts/install-plugin.sh",
		"install:debug:all": "PROFILE=debug INSTALL_AUV3=1 REMOVE_INSTALLED_AUV3=0 bash ../../scripts/install-plugin.sh",
		"bundle-install": "bash ../../scripts/build-plugin.sh --release && bash ../../scripts/install-plugin.sh",
		"bundle-install:debug": "bash ../../scripts/build-plugin.sh debug && PROFILE=debug bash ../../scripts/install-plugin.sh",
		"bundle-install:all": "BUILD_AUV3=1 bash ../../scripts/build-plugin.sh --release && INSTALL_AUV3=1 REMOVE_INSTALLED_AUV3=0 bash ../../scripts/install-plugin.sh",
		"bundle-install:debug:all": "BUILD_AUV3=1 bash ../../scripts/build-plugin.sh debug && PROFILE=debug INSTALL_AUV3=1 REMOVE_INSTALLED_AUV3=0 bash ../../scripts/install-plugin.sh",
		"webview:dev:test": "cd webview && bun run dev:test",
		"webview:test:unit": "cd webview && bun run test:unit",
		"webview:test:unit:watch": "cd webview && bun run test:unit:watch",
		"webview:test:browser": "cd webview && bun run test:browser",
		"webview:test:all": "cd webview && bun run test:all",
		"webview:test:e2e": "cd webview && bun run test:e2e",
		"webview:test:e2e:ui": "cd webview && bun run test:e2e:ui",
		"webview:test:e2e:debug": "cd webview && bun run test:e2e:debug",
		"package:installer": "bun run package:installer:macos && bun run package:installer:windows && bun run package:installer:linux",
		"package:installer:macos": "bun run ../../scripts/package-plugin-installers.mjs --platform macos",
		"package:installer:windows": "bun run ../../scripts/package-plugin-installers.mjs --platform windows",
		"package:installer:linux": "bun run ../../scripts/package-plugin-installers.mjs --platform linux"
	}
}
